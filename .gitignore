# OS noise
.DS_Store
Thumbs.db

# Editor swap / backup files
*.swp
*.swo
*~

# Logs
*.log

# Local-only notes (use these suffixes for anything you want to keep out of git)
*.local.md
*.private.md

# In-session uploads (screenshots, images dropped into chat) — local-only
.uploads/

# Python
__pycache__/
*.pyc
*.egg-info/
build/
dist/
.eggs/

# Test/dev venvs — created by the Makefile; never committed
.test-venv/
.venv/
venv/

# Secrets — scoped keys live outside the repo (~/.config/monad/), never in git
*.key

# Internal process / tooling / cross-session coordination — NOT product, stays local.
# Principle: the public tree carries PRODUCT ONLY. These were purged from git history
# pre-public (they carried the maintainer home path, Monad infra refs, and candid
# internal routing/cost-tier reasoning). The files remain ON DISK — TangleClaw, Prawduct,
# and the shared-doc registrations read them locally — they're just never tracked.
.claude/
.tangleclaw/
.prawduct/
CLAUDE.md
C1-BUILD-REPORT.md
TANGLEBRAIN-STATUS.md

# Personal config overrides — keep your real roster/settings out of git
# (the shipped config/*.yaml stay generic; your real deployment lives in an
#  external/override file referenced at runtime)
*.local.yaml
*.local.yml
roster.local.yaml
settings.local.yaml

# Env files
.env
.env.*
